<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PocketPans — Fillable Bakeware for Cupcakes & Personal Pizzas</title>
<meta name="description" content="Premium silicone bakeware with a unique fillable insert system. Make cream-filled cupcakes, deep dish pizzas, hand pies, and more.">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600;9..144,700;9..144,900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
:root {
  --cream: #faf5ee;
  --cream-deep: #f1e9d8;
  --terracotta: #c2553e;
  --terracotta-deep: #8e3a28;
  --red: #d33a3a;
  --ink: #1a1410;
  --ink-soft: #4a3f36;
  --warm-gray: #8a7a6c;
  --line: #d9cdb8;
  --slider-duration: 1.2s;
  --fade-duration: 0.55s;
}

* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
  font-family: 'Inter', -apple-system, sans-serif;
  font-weight: 400;
  line-height: 1.6;
  color: var(--ink);
  background: var(--cream);
  overflow-x: hidden;
}
.serif { font-family: 'Fraunces', Georgia, serif; }

/* HEADER */
header {
  position: sticky; top: 0; z-index: 100;
  background: rgba(250, 245, 238, 0.92);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
  border-bottom: 1px solid var(--line);
}
.nav {
  max-width: 1400px; margin: 0 auto;
  padding: 1.1rem 5%;
  display: flex; justify-content: space-between; align-items: center;
}
.logo {
  font-family: 'Fraunces', serif;
  font-weight: 700; font-size: 1.6rem;
  letter-spacing: -0.02em;
  color: var(--ink);
  cursor: pointer; background: none; border: none;
  display: flex; align-items: baseline; gap: 0.3rem;
}
.logo .accent { color: var(--terracotta); font-style: italic; }
.nav-meta {
  font-size: 0.75rem; letter-spacing: 0.18em;
  text-transform: uppercase; color: var(--warm-gray);
  font-weight: 500;
}

/* HERO */
.hero {
  position: relative;
  height: 78vh;
  min-height: 540px;
  max-height: 780px;
  overflow: hidden;
  background: var(--ink);
}

@media (max-width: 768px) {
  .hero {
    height: 35vh !important;
    min-height: 250px;
  }
}

.image-layer {
  position: absolute;
  top: 0;
  height: 100%;
  width: 50%;
  overflow: hidden;
}
.image-layer .img-wrap {
  position: absolute;
  top: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.image-layer .img-wrap > img,
.image-layer .img-wrap > .placeholder-bg {
  width: 100%;
  height: 100%;
  object-fit: cover;
  user-select: none;
  -webkit-user-drag: none;
  pointer-events: none;
}

#cupcake-layer {
  left: 0;
  z-index: 2;
  clip-path: inset(0 0 0 0);
  transition: clip-path 0s;
}
#cupcake-layer .img-wrap { left: 0; width: 100%; }

#pizza-layer {
  left: 50%;
  z-index: 1;
  clip-path: inset(0 0 0 0);
  transition: clip-path 0s;
}
#pizza-layer .img-wrap { left: 0; width: 100%; }

.image-layer.full-width { width: 100%; left: 0; }
#cupcake-layer.full-width .img-wrap { left: 0; width: 50%; }
#pizza-layer.full-width .img-wrap { left: 50%; width: 50%; }

.image-layer.animating {
  transition: clip-path var(--slider-duration) cubic-bezier(0.7, 0, 0.3, 1);
}

/* Hero labels */
.hero-label {
  position: absolute;
  bottom: 4rem;
  z-index: 5;
  color: var(--cream);
  font-family: 'Fraunces', serif;
  font-weight: 300;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  font-size: 0.85rem;
  opacity: 0.85;
  pointer-events: none;
  transition: opacity 0.4s;
}
.hero-label .name {
  display: block;
  font-family: 'Fraunces', serif;
  font-weight: 400;
  font-style: italic;
  font-size: 2.2rem;
  letter-spacing: -0.01em;
  text-transform: none;
  margin-top: 0.4rem;
  opacity: 0.95;
}
.hero-label.left { left: 6%; }
.hero-label.right { right: 6%; text-align: right; }
@media (max-width: 768px) {
  .hero-label { bottom: 3rem; font-size: 0.6rem; }
  .hero-label .name { font-size: 1rem; }
}

/* Divider */
.divider {
  position: absolute;
  top: 0;
  left: 50%;
  width: 3px;
  height: 100%;
  background: var(--cream);
  box-shadow: 0 0 32px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.15);
  z-index: 11;
  transform: translateX(-50%);
  pointer-events: none;
}
.divider.animating {
  transition: left var(--slider-duration) cubic-bezier(0.7, 0, 0.3, 1);
}

/* Desktop handle */
.handle-desktop {
  position: absolute;
  top: 50%;
  left: -36px;
  width: 72px; height: 72px;
  background: var(--cream);
  border-radius: 50%;
  box-shadow: 0 10px 40px rgba(0,0,0,0.5), 0 0 0 1px rgba(0,0,0,0.04);
  transform: translateY(-50%);
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  z-index: 12;
  gap: 6px;
}
.handle-desktop .arrow {
  font-family: 'Fraunces', serif;
  font-weight: 300;
  font-size: 1.4rem;
  color: var(--terracotta-deep);
  opacity: 0.85;
}
@media (max-width: 768px) { .handle-desktop { display: none; } }

/* Slider drag area */
.slider-area {
  position: absolute;
  inset: 0;
  z-index: 10;
  cursor: ew-resize;
  touch-action: pan-y;
}
@media (max-width: 768px) {
  .slider-area { display: none; pointer-events: none; }
}

/* Mobile pill controls */
.pill-controls {
  display: none;
  position: absolute;
  bottom: 1.2rem;
  left: 0; right: 0;
  z-index: 15;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}
.pill {
  pointer-events: auto;
  cursor: pointer;
  background: var(--cream);
  color: var(--ink);
  border: none;
  font-family: 'Fraunces', serif;
  font-weight: 500;
  letter-spacing: 0.04em;
  box-shadow: 0 6px 28px rgba(0,0,0,0.45);
  transition: transform 0.3s ease, background 0.3s, color 0.3s;
  -webkit-tap-highlight-color: transparent;
  height: 48px;
  border-radius: 999px;
  padding: 0 1.2rem;
  font-size: 0.9rem;
}
.pill-side { margin: 0 0.5rem; }
.pill-center {
  width: 48px; height: 48px;
  border-radius: 50%;
  font-size: 1.2rem; font-weight: 700;
  color: var(--terracotta);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 6px 28px rgba(0,0,0,0.45), inset 0 0 0 2px var(--terracotta);
}
.pill-side.active { background: var(--terracotta); color: var(--cream); }
.pill-center.active { background: var(--terracotta); color: var(--cream); }
@media (max-width: 768px) { .pill-controls { display: flex; } }

/* Sections */
.content-wrap { position: relative; }
.section {
  opacity: 0;
  pointer-events: none;
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  visibility: hidden;
}
.section.active {
  opacity: 1;
  pointer-events: auto;
  position: relative;
  visibility: visible;
  transition: opacity var(--fade-duration) ease;
}

/* ... (Rest of CSS remains unchanged as per your original file) ... */
.brand-intro { padding: 6rem 5% 4rem; text-align: center; background: var(--cream); }
.eyebrow { font-family: 'Inter', sans-serif; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.25em; text-transform: uppercase; color: var(--terracotta); margin-bottom: 1.4rem; }
.brand-intro h1 { font-family: 'Fraunces', serif; font-size: clamp(2.6rem, 6vw, 4.8rem); font-weight: 400; line-height: 1.05; letter-spacing: -0.025em; max-width: 900px; margin: 0 auto 1.6rem; color: var(--ink); }
.brand-intro h1 em { font-style: italic; color: var(--terracotta); font-weight: 500; }
.brand-intro .lead { font-family: 'Fraunces', serif; font-weight: 300; font-size: clamp(1.1rem, 1.8vw, 1.4rem); line-height: 1.5; max-width: 640px; margin: 0 auto; color: var(--ink-soft); }
.concept { background: var(--cream-deep); padding: 7rem 5%; }
.concept-grid { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
@media (max-width: 768px) { .concept-grid { grid-template-columns: 1fr; gap: 2.5rem; } }
.concept-visual { aspect-ratio: 4/5; background: linear-gradient(135deg, #d9c5a0, #b89368); border-radius: 8px; position: relative; overflow: hidden; box-shadow: 0 30px 80px -20px rgba(0,0,0,0.3); }
.concept-text h2 { font-family: 'Fraunces', serif; font-size: clamp(2rem, 3.6vw, 3rem); font-weight: 400; line-height: 1.1; letter-spacing: -0.02em; margin-bottom: 1.5rem; }
.concept-text h2 em { font-style: italic; color: var(--terracotta); font-weight: 500; }
.capabilities { background: var(--cream); padding: 7rem 5%; }
.capabilities-header { text-align: center; margin-bottom: 4rem; }
.capabilities-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
@media (max-width: 900px) { .capabilities-grid { grid-template-columns: repeat(2, 1fr); } }
.cap-card { background: var(--cream-deep); padding: 2.5rem 2rem; border-radius: 4px; border-top: 3px solid var(--terracotta); }
.variant-anchors { background: var(--cream-deep); padding: 7rem 5%; }
.anchor-row { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
@media (max-width: 768px) { .anchor-row { grid-template-columns: 1fr; } }
.anchor-card { background: var(--cream); border: 1px solid var(--line); padding: 3rem 2.5rem; display: block; text-decoration: none; color: inherit; }
.product-view { background: var(--cream); min-height: 60vh; }
.product-hero { padding: 5rem 5% 3rem; text-align: center; }
.buy-cta { background: var(--terracotta); color: var(--cream); padding: 1.1rem 2.6rem; border: none; border-radius: 999px; font-weight: 600; cursor: pointer; }
footer { background: var(--ink); color: var(--cream); padding: 3rem 5%; text-align: center; }
</style>
</head>
<body>

<header>
  <div class="nav">
    <button class="logo" id="logo-home">
      <span>Pocket</span><span class="accent">Pans</span>
    </button>
    <div class="nav-meta">Fillable Bakeware · by Paulegone</div>
  </div>
</header>

<section class="hero" id="hero">
  <div class="image-layer full-width" id="pizza-layer">
    <div class="img-wrap"><div class="placeholder-bg" style="background: #a54a3a"></div></div>
  </div>
  <div class="image-layer full-width" id="cupcake-layer">
    <div class="img-wrap"><div class="placeholder-bg" style="background: #d99c5e"></div></div>
  </div>

  <div class="hero-label left">Standard<span class="name">PocketCakes</span></div>
  <div class="hero-label right">Personal<span class="name">PocketPies</span></div>

  <div class="divider" id="divider">
    <div class="handle-desktop"><span class="arrow">‹</span><span class="arrow">›</span></div>
  </div>

  <div class="slider-area" id="slider-area"></div>

  <div class="pill-controls">
    <button class="pill pill-side" id="pill-left">Cakes</button>
    <button class="pill pill-center active" id="pill-center">P</button>
    <button class="pill pill-side" id="pill-right">Pies</button>
  </div>
</section>

<div class="content-wrap">
  <div class="section active" id="brand-section">
    <div class="brand-intro"><h1>One pan, <em>two sizes.</em></h1></div>
  </div>
  <div class="section" id="cupcake-section">
    <div class="product-hero"><h2>PocketCakes</h2></div>
  </div>
  <div class="section" id="pizza-section">
    <div class="product-hero"><h2>PocketPies</h2></div>
  </div>
</div>

<footer>
  <div class="footer-inner">
    <div class="brand">PocketPans</div>
    <div class="meta">© 2026 · Paulegone</div>
  </div>
</footer>

<script>
(function() {
  const divider = document.getElementById('divider');
  const cupcakeLayer = document.getElementById('cupcake-layer');
  const pizzaLayer = document.getElementById('pizza-layer');
  const sliderArea = document.getElementById('slider-area');
  const brandSection = document.getElementById('brand-section');
  const cupcakeSection = document.getElementById('cupcake-section');
  const pizzaSection = document.getElementById('pizza-section');
  const pillLeft = document.getElementById('pill-left');
  const pillRight = document.getElementById('pill-right');
  const pillCenter = document.getElementById('pill-center');

  let currentState = 'brand';

  function setDivider(percent, animate) {
    const elements = [divider, cupcakeLayer, pizzaLayer];
    elements.forEach(el => el.classList.toggle('animating', animate));
    divider.style.left = percent + '%';
    cupcakeLayer.style.clipPath = 'inset(0 ' + (100 - percent) + '% 0 0)';
    pizzaLayer.style.clipPath = 'inset(0 0 0 ' + percent + '%)';
  }

  function transitionTo(state) {
    if (state === currentState) return;
    currentState = state;
    
    brandSection.classList.toggle('active', state === 'brand');
    cupcakeSection.classList.toggle('active', state === 'cupcake');
    pizzaSection.classList.toggle('active', state === 'pizza');
    
    pillLeft.classList.toggle('active', state === 'cupcake');
    pillRight.classList.toggle('active', state === 'pizza');
    pillCenter.classList.toggle('active', state === 'brand');

    const target = state === 'cupcake' ? 100 : (state === 'pizza' ? 0 : 50);
    setDivider(target, true);
  }

  pillLeft.addEventListener('click', () => transitionTo('cupcake'));
  pillRight.addEventListener('click', () => transitionTo('pizza'));
  pillCenter.addEventListener('click', () => transitionTo('brand'));

  // Only add drag listeners if not on mobile
  if (window.innerWidth > 768) {
    // ... (drag logic from original file)
  }
})();
</script>

</body>
</html>
